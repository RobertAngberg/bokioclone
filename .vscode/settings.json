{
  "css.validate": true,
  "editor.inlineSuggest.enabled": true,
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "javascript": "javascript",
    "css": "css"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "files.exclude": {
    ".eslintrc.json": true,
    ".next": true,
    ".vercel": true,
    ".vscode": true,
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/*.cs.meta": true,
    "**/CVS": true,
    "**/Thumbs.db": true,
    "app/.vscode": true
  },
  "hide-files.files": [],
  "explorer.excludeGitIgnore": true
}
